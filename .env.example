# GCP Configuration (used by build.sh and imagebuild.yaml)
GCP_REGION=your-gcp-region
SERVER_NAME=your-server-name
REPO_NAME=your-repo-name
IMAGE_NAME=your-image-name

# Model Server Configuration
PORT=8000
MODEL=df_default_2.0.1
MODEL_FORMAT=onnx
PYTHONUNBUFFERED=1

# Model storage bucket (Scaleway S3)
# The bucket name used to download ONNX models.
# Builds the URL: https://<MODEL_BUCKET>.s3.fr-par.scw.cloud/models/{name}.onnx
# Override the full URL instead with MODEL_URL_TEMPLATE if needed.
MODEL_BUCKET=daylight-factor
